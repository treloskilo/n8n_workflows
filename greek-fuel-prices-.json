      "name": "Summarize"
    },
    {
      "parameters": {
        "jsCode": "// Access the aggregated data from the Summarize node\nconst data = $input.all()[0].json;\n\nlet tableRows = '';\n\n// Loop through the data to build each row\nfor (let i = 0; i < data.appended_date.length; i++) {\n  tableRows += `\n    <tr>\n      <td style=\"border: 1px solid #ddd; padding: 10px;\">${data.appended_date[i]}</td>\n      <td style=\"border: 1px solid #ddd; padding: 10px; text-align: center;\">${data.appended_min_price[i]}€</td>\n      <td style=\"border: 1px solid #ddd; padding: 10px; text-align: center;\">${data.appended_avg_price[i]}€</td>\n      <td style=\"border: 1px solid #ddd; padding: 10px; text-align: center;\">${data.appended_max_price[i]}€</td>\n    </tr>\n  `;\n}\n\nconst htmlContent = `\n<div style=\"font-family: Arial, sans-serif; max-width: 600px; color: #333;\">\n  <h2 style=\"color: #004a99; border-bottom: 2px solid #004a99; padding-bottom: 10px;\">\n    Daily Fuel Price Report (Last 5 Days)\n  </h2>\n  <table style=\"border-collapse: collapse; width: 100%; margin-top: 15px;\">\n    <thead>\n      <tr style=\"background-color: #004a99; color: white;\">\n        <th style=\"padding: 12px; border: 1px solid #ddd; text-align: left;\">Ημερομηνία</th>\n        <th style=\"padding: 12px; border: 1px solid #ddd;\">Ελάχιστη Τιμή</th>\n        <th style=\"padding: 12px; border: 1px solid #ddd;\">Μέση Τιμή</th>\n        <th style=\"padding: 12px; border: 1px solid #ddd;\">Μέγιστη Τιμή</th>\n      </tr>\n    </thead>\n    <tbody>\n      ${tableRows}\n    </tbody>\n  </table>\n  <p style=\"font-size: 11px; color: #888; margin-top: 20px;\">\n    Πηγή: Παρατηρητήριο Τιμών Υγρών Καυσίμων (fuelprices.gr)\n  </p>\n</div>\n`;\n\nreturn { htmlTable: htmlContent };"
      },
