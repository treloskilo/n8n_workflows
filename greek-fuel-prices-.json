      ],
      "id": "877c6cd5-a7ef-403c-9ebe-b0eae085b333",
      "name": "HTML"
    },
    {
      "parameters": {
        "jsCode": "const datesArray = $input.all()[0].json.dates;\nconst minArray = $input.all()[0].json.min_prices;\nconst avgArray = $input.all()[0].json.avg_prices;\nconst maxArray = $input.all()[0].json.max_prices;\n\nconst cleanData = [];\nconst currentYear = 2026; \n\nfor (let i = 7; i < datesArray.length; i++) {\n    let avgIdx = i - 6; \n    let minIdx = i - 4;\n    let maxIdx = i - 6;\n\n    if (avgArray[avgIdx] && avgArray[avgIdx].includes(',')) {\n        // 1. Extract the \"DD/MM\" part from \"Παρ, 17/04\"\n        const rawDate = datesArray[i].split(' ')[1]; // Gets \"17/04\"\n        const [day, month] = rawDate.split('/');\n        \n        // 2. Format as DD-MM-YYYY\n        const formattedDate = `${day}-${month}-${currentYear}`;\n\n        cleanData.push({\n            date: formattedDate,\n            min_price: parseFloat(minArray[minIdx].replace(',', '.')),\n            avg_price: parseFloat(avgArray[avgIdx].replace(',', '.')),\n            max_price: parseFloat(maxArray[maxIdx].replace(',', '.')),\n            fuel_type: \"Diesel Kinisis & Enisximeno\"\n        });\n    }\n}\n\nreturn cleanData;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -112,
        -208
      ],
      "id": "d8df9906-4a2e-4365-8adb-a628010923b6",
